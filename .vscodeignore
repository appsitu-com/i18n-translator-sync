# Development and source files
.vscode/**
.vscode-test/**
.github/**
src/**
tests/**
scripts/**

# Documentation (not needed in extension)
doc/**
CONTRIBUTING.md
ROADMAP.md
RENAME_PLAN.md
TODO.md

# Config and environment files
.gitignore
/translator.env
.env
.env-example
/translator.json
keys/**

# Build config
**/tsconfig.json
**/vitest.config.ts
**/vite.config.ts
**/vite.cli.config.ts
**/vite.shared.ts
**/eslint.config.js
**/.eslintrc.json
**/.eslintignore

# Build artifacts and other exclusions
**/*.map
**/*.ts
**/*.tgz
**/*.vsix
.git/**
coverage/**
releases/**
test-project/**

# Exclude all node_modules by default and include only native runtime deps.
node_modules/**
!node_modules/better-sqlite3/**
!node_modules/bindings/**
!node_modules/file-uri-to-path/**
