{
  "sourcePaths": ["i18n/en", "i18n/en.json"],
  "sourceLocale": "en",
  "targetLocales": ["en-US", "es", "fr", "de", "zh-CN"],
  "enableBackTranslation": true,
  "defaultMarkdownEngine": "google",
  "defaultJsonEngine": "google",
  "engineOverrides": {
    "copy": ["en-US"],
    "google": ["fr", "de", "zh-CN"],
    "azure": ["es"]
  },
  "translator": {
    "copy": {},
    "google": {
      "apiKey": "${GOOGLE_TRANSLATION_KEY}",
      "endpoint": "${GOOGLE_TRANSLATION_URL}"
    },
    "azure": {
      "apiKey": "${AZURE_TRANSLATION_KEY}",
      "region": "${AZURE_TRANSLATION_REGION}",
      "endpoint": "${AZURE_TRANSLATION_URL}"
    }
  }
}
