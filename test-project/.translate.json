{
  "sourcePaths": ["i18n/en", "i18n/en.json"],
  "sourceLocale": "en",
  "targetLocales": ["en-US", "es", "fr", "de", "zh-CN"],
  "enableBackTranslation": true,
  "defaultMarkdownEngine": "copy",
  "defaultJsonEngine": "copy",
  "engineOverrides": {
    "copy": ["en-US"],
    "deepl": ["fr", "de"],
    "azure": ["es:en"]
  }
}
