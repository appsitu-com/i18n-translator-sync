{
  "sourcePaths": ["i18n/en", "i18n/en.json"],
  "sourceLocale": "en",
  "targetLocales": ["en-US", "es", "fr", "de", "zh-CN"],
  "enableBackTranslation": true,
  "defaultMarkdownEngine": "google",
  "defaultJsonEngine": "google",
  "engineOverrides": {
    "copy": ["en-US"],
    "google": ["fr", "de", "zh-CN"],
    "azure": ["es"]
  }
}
