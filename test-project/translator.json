{
  "csvExportPath": "translator.csv",
  "autoExport": true,
  "autoImport": true,
  "sourcePaths": ["i18n/en", "i18n/en.json"],
  "sourceLocale": "en",
  "targetLocales": ["en-US", "es", "fr", "hi", "ur", "de", "zh-CN"],
  "enableBackTranslation": true,
  "defaultMarkdownEngine": "google",
  "defaultJsonEngine": "google",
  "excludeKeys": ["native", "code"],
  "excludeKeyPaths": [],
  "copyOnlyFiles": ["index.ts"],
  "engineOverrides": {
    "copy": ["en-US"],
    "google": ["zh-CN"],
    "deepl": ["fr", "de", "zh-CN"],
    "azure": ["es"]
  },
  "translator": {
    "copy": {},
    "google": {
      "apiKey": "${GOOGLE_TRANSLATION_KEY}",
      "endpoint": "${GOOGLE_TRANSLATION_URL}",
      "googleProjectId": "${GOOGLE_TRANSLATION_PROJECT_ID}",
      "googleLocation": "${GOOGLE_TRANSLATION_LOCATION}"
    },
    "azure": {
      "apiKey": "${AZURE_TRANSLATION_KEY}",
      "region": "${AZURE_TRANSLATION_REGION}",
      "endpoint": "${AZURE_TRANSLATION_URL}"
    },
    "deepl": {
      "apiKey": "${DEEPL_TRANSLATION_KEY}",
      "endpoint": "${DEEPL_TRANSLATION_URL}",

      // Locale mappings for DeepL (uses uppercase language codes)
      "langMap": {
        "en": "EN-US",
        "zh-CN": "ZH-HANS",
        "zh-TW": "ZH-HANT",
        "zh-HK": "ZH-HANT"
      }
    }
  }
}
