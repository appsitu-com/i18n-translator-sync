# You only need to configure keys for the translation APIs you configure in translator.json

## Create an Azure Translate API key at https://portal.azure.com
# Get API key from: https://learn.microsoft.com/azure/ai-services/translator/translator-how-to-signup
# https://www.youtube.com/watch?v=l6Rl4HSZVvg
AZURE_TRANSLATION_KEY='XXXXXXXXXXXXXXXXXXXXXXXXX'
AZURE_TRANSLATION_REGION='westus'
AZURE_TRANSLATION_URL='https://api.cognitive.microsofttranslator.com'

## Create a Google Translate API key at https://cloud.google.com/
# https://www.youtube.com/watch?v=mh0y8BZlWuI
# GOOGLE_TRANSLATION_KEY is a path to a Google service credential JSON file
GOOGLE_TRANSLATION_KEY='keys/google-service-account.json'
GOOGLE_TRANSLATION_URL='https://translation.googleapis.com'
GOOGLE_TRANSLATION_PROJECT_ID='your-google-cloud-project-id'
GOOGLE_TRANSLATION_LOCATION='global'

## Create a DeepL API key at https://deepl.com/
# https://www.youtube.com/watch?v=VgpxUH7SbSY
DEEPL_TRANSLATION_KEY='ZZZZZZZZZZZZZZZZZZZZZZZZZZZZZ'
DEEPL_TRANSLATION_URL='https://api-free.deepl.com'

## Create a Google Gemini API key at https://ai.google.dev/gemini-api/docs/api-key
# https://www.youtube.com/watch?v=o8iyrtQyrZM
GEMINI_API_KEY='SSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSSS'
GEMINI_API_URL='https://generativelanguage.googleapis.com/v1beta'

## NOT YET SUPPORTED
# Create a Open Router API key at https://openrouter.ai/
# https://www.youtube.com/watch?v=VgpxUH7SbSY
OPENROUTER_API_NAME='QQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQQ'
OPENROUTER_API_KEY='RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR'
OPENROUTER_API_URL='https://openrouter.ai/api/v1/chat/completions'
