{
  "sourcePaths": ["i18n/en"],
  "sourceLocale": "en",
  "targetLocales": ["es", "fr", "de", "ja", "zh-CN"],
  "enableBackTranslation": false,
  "defaultMarkdownEngine": "azure",
  "defaultJsonEngine": "google",
  "engineOverrides": {
    "deepl": ["fr", "de"],
    "azure": ["es:en", "ja:en"]
  },
  "translator": {
    "copy": {},
    "google": {
      "apiKey": "${GOOGLE_TRANSLATION_KEY}",
      "endpoint": "${GOOGLE_TRANSLATION_URL}",
      "langMap": {
        "zh-CN": "zh-cn",
        "zh-TW": "zh-tw",
        "zh-Hans": "zh-cn",
        "zh-Hant": "zh-tw"
      }
    },
    "azure": {
      "apiKey": "${AZURE_TRANSLATION_KEY}",
      "region": "${AZURE_TRANSLATION_REGION}",
      "endpoint": "${AZURE_TRANSLATION_URL}",
      "langMap": {
        "zh-CN": "zh-Hans",
        "zh-Hans": "zh-Hans",
        "zh-TW": "zh-Hant",
        "zh-HK": "zh-Hant",
        "zh-Hant": "zh-Hant",
        "fr-ca": "fr-ca",
