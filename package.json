{
  "name": "i18n-translator-vscode",
  "description": "Extension for translating Markdown and JSON files using AI translation services",
  "displayName": "i18n Translator",
  "publisher": "appsitu.com",
  "preview": true,
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.103.0"
  },
  "keywords": [
    "i18n",
    "translation",
    "localization",
    "azure",
    "google",
    "deepl",
    "gemini",
    "markdown",
    "json"
  ],
  "homepage": "https://github.com/tohagan/vscode-i18n-translator-ext",
  "repository": {
    "type": "git",
    "url": "https://github.com/tohagan/vscode-i18n-translator-ext.git"
  },
  "bugs": {
    "url": "https://github.com/tohagan/vscode-i18n-translator-ext/issues"
  },
  "author": {
    "name": "Tony O'Hagan"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0078d4",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "i18n-translator": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "build:cli": "tsc -p ./",
    "cli": "yarn build && node ./dist/cli/index.js test-project",
    "cli:force": "yarn build && node ./dist/cli/index.js test-project --force",
    "cli:debug": "yarn build && node --inspect ./dist/cli/index.js test-project",
    "cli:clean": "cd test-project && find i18n -maxdepth 1 \\( -name '*.json' ! -name 'en.json' \\) -o \\( -type d ! -name 'en' ! -name 'i18n' \\) | xargs rm -rf",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild:sqlite": "node ./scripts/rebuild-sqlite.js",
    "rebuild:sqlite:electron": "node ./scripts/rebuild-sqlite.js --electron",
    "rebuild:sqlite:electron:quick": "node ./scripts/rebuild-sqlite.js --electron --skip-if-unchanged",
    "rebuild:quick": "node ./scripts/rebuild-sqlite.js --skip-clean",
    "pretest": "yarn rebuild:sqlite",
    "vscode:prepublish": "yarn rebuild:sqlite:electron && yarn build",
    "package": "node scripts/package-extension.js",
    "package:regenerate-icon": "node scripts/package-extension.js --force-icon-generation",
    "package:quick": "npx @vscode/vsce package",
    "test:cov": "vitest run --coverage",
    "version:update": "node scripts/update-version.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "vsce": {
    "dependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.1",
    "@types/vscode": "^1.103.0",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@vitest/coverage-v8": "^3.2.4",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.35.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "sharp": "^0.34.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.1",
    "dotenv": "^17.2.1",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.3",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "remark-stringify": "^11.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.1.5"
  },
  "contributes": {
    "commands": [
      {
        "command": "translator.start",
        "title": "Translator: Start"
      },
      {
        "command": "translator.stop",
        "title": "Translator: Stop"
      },
      {
        "command": "translator.restart",
        "title": "Translator: Restart"
      },
      {
        "command": "translator.push",
        "title": "Translator: Push translations to MateCat"
      },
      {
        "command": "translator.pull",
        "title": "Translator: Pull translations from MateCat"
      },
      {
        "command": "translator.showOutput",
        "title": "Translator: Show Output"
      }
    ],
    "configuration": {
      "title": "Markdown & JSON Translator",
      "properties": {
        "translator.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the translator when opening a workspace"
        },
        "translator.sourceLocale": {
          "type": "string",
          "default": "en"
        },
        "translator.targetLocales": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "fr-FR"
          ]
        },
        "translator.enableBackTranslation": {
          "type": "boolean",
          "default": true
        },
        "translator.defaultMarkdownEngine": {
          "type": "string",
          "enum": [
            "azure",
            "google",
            "deepl",
            "gemini",
            "copy"
          ],
          "default": "azure"
        },
        "translator.defaultJsonEngine": {
          "type": "string",
          "enum": [
            "azure",
            "google",
            "deepl",
            "gemini",
            "copy"
          ],
          "default": "google"
        },
        "translator.engineOverrides": {
          "type": "object",
          "default": {
            "deepl": [
              "ar",
              "bg",
              "cs",
              "da",
              "de",
              "el",
              "en",
              "en-GB",
              "en-US",
              "es",
              "es-419",
              "et",
              "fi",
              "fr",
              "he",
              "hu",
              "id",
              "it",
              "ja",
              "ko",
              "lt",
              "lv",
              "nb",
              "nl",
              "pl",
              "pt",
              "pt-BR",
              "pt-PT",
              "ro",
              "ru",
              "sk",
              "sl",
              "sv",
              "th",
              "tr",
              "uk",
              "vi",
              "zh",
              "zh-Hans",
              "zh-Hant"
            ],
            "copy": [
              "en-US"
            ]
          }
        },
        "translator.azure": {
          "type": "object",
          "default": {
            "key": "env:AZURE_TRANSLATOR_KEY",
            "region": "env:AZURE_REGION"
          }
        },
        "translator.google": {
          "type": "object",
          "default": {
            "key": "env:GOOGLE_TRANSLATE_KEY"
          }
        },
        "translator.deepl": {
          "type": "object",
          "default": {
            "key": "env:DEEPL_TRANSLATE_KEY",
            "free": true
          }
        },
        "translator.gemini": {
          "type": "object",
          "default": {
            "key": "env:GEMINI_API_KEY",
            "geminiModel": "gemini-1.5-pro",
            "temperature": 0.1,
            "maxOutputTokens": 1024
          }
        },
        "translator.matecat": {
          "type": "object",
          "default": {
            "pushUrl": "env:MATECAT_PUSH_URL",
            "pullUrl": "env:MATECAT_PULL_URL",
            "apiKey": "env:MATECAT_API_KEY",
            "projectId": "env:MATECAT_PROJECT_ID"
          },
          "description": "MateCat API configuration. pushUrl/pullUrl may include {projectId} template."
        }
      }
    }
  }
}
