{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: build",
      "type": "shell",
      "command": "pnpm",
      "args": ["build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "pnpm: test",
      "type": "shell",
      "command": "pnpm",
      "args": ["test"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "pnpm: prepare-debug",
      "type": "shell",
      "command": "pnpm",
      "args": ["rebuild:sqlite:electron"],
      "dependsOn": ["pnpm: build"],
      "presentation": {
        "reveal": "silent",
        "close": true
      }
    }
  ]
}
